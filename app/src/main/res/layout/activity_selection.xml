<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Food Bridge"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha como deseja entrar:"
        android:layout_marginBottom="40dp"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/btnSelectionDonor"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🌱 SOU DOADOR"
        android:backgroundTint="#2E7D32"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSelectionReceiver"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🏠 SOU UMA ONG"
        android:backgroundTint="#1976D2"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVerMapa"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🗺️ VER MAPA DE DOAÇÕES"
        android:backgroundTint="#F57C00"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/btnViewAnalytics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver Relatórios de Impacto"
        android:layout_marginTop="16dp"
        android:textColor="#757575"
        android:padding="8dp"/>
    <TextView
        android:id="@+id/btnPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤 Meu Perfil"
        android:layout_marginTop="8dp"
        android:textColor="#1976D2"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/btnSair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sair"
        android:layout_marginTop="8dp"
        android:textColor="#D32F2F"
        android:padding="8dp"/>

</LinearLayout>